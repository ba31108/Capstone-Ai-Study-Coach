# Copy this file to .env and fill in your real values
# NEVER commit the real .env file to git

PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/studyCoachAI?retryWrites=true&w=majority
JWT_SECRET=replace_this_with_a_long_random_secret_string
FRONTEND_URL=https://your-frontend-name.vercel.app
NODE_ENV=production

# Admin seed script (used by: npm run seed:admin)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@studycoach.com
ADMIN_PASSWORD=ChangeMe123!
